#!/usr/bin/env bash
# .githooks/pre-push — run release checks before every push.
#
# Activated with:  git config core.hooksPath .githooks
# (run once per clone, or via scripts/setup-hooks.sh)

set -euo pipefail

ROOT="$(cd "$(dirname "$0")/.." && pwd)"

echo "[pre-push] Running release version check..."
bash "$ROOT/scripts/check_release.sh"
